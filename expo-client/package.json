{
  "name": "classflow-expo-client",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev:web": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-web.ps1",
    "build:web": "expo export --platform web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "db:check": "node scripts/check-supabase-schema.mjs",
    "db:apply": "node ../scripts/apply-supabase-sql.mjs",
    "db:apply:textlk": "node ../scripts/apply-supabase-file.mjs supabase/migrations/20260629_text_lk_sms.sql"
  },
  "dependencies": {
    "@expo/vector-icons": "latest",
    "@react-native-async-storage/async-storage": "latest",
    "@supabase/supabase-js": "latest",
    "expo": "latest",
    "expo-constants": "latest",
    "expo-font": "latest",
    "expo-linear-gradient": "latest",
    "expo-linking": "latest",
    "expo-router": "latest",
    "expo-splash-screen": "latest",
    "expo-sqlite": "^56.0.5",
    "expo-status-bar": "latest",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.1",
    "qrcode": "^1.5.4",
    "react": "latest",
    "react-dom": "latest",
    "react-native": "latest",
    "react-native-gesture-handler": "latest",
    "react-native-reanimated": "latest",
    "react-native-safe-area-context": "latest",
    "react-native-screens": "latest",
    "react-native-url-polyfill": "latest",
    "react-native-web": "latest"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "latest",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "typescript": "latest"
  }
}
